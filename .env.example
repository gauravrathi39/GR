# ---- Backend environment ----
# Copy to .env and fill in real values. Never commit .env.

# Port the Express API listens on
PORT=5000

# MongoDB connection string (local or Atlas)
# Local example:  mongodb://127.0.0.1:27017/ai-travel-planner
# Atlas example:  mongodb+srv://<user>:<pass>@<cluster>/ai-travel-planner
MONGODB_URI=mongodb://127.0.0.1:27017/ai-travel-planner

# Secret used to sign JWTs. Use a long random string in production.
JWT_SECRET=change-me-to-a-long-random-secret
# How long issued tokens are valid
JWT_EXPIRES_IN=7d

# Google Gemini API key (https://aistudio.google.com/apikey)
GEMINI_API_KEY=your-gemini-api-key
# Gemini model id
GEMINI_MODEL=gemini-2.5-flash

# Frontend origin allowed by CORS (must match where Next.js runs)
CLIENT_ORIGIN=http://localhost:3000

# Set to "true" only when serving over HTTPS (production). Keep false for local dev.
COOKIE_SECURE=false

# Node environment
NODE_ENV=development
